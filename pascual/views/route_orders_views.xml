<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_route_order_search" model="ir.ui.view">
            <field name="name">view.routeorder.search</field>
            <field name="model">route.order</field>
            <field name="arch" type="xml">
                <search string="Ruta de Ordenes">
                    <field name="name"/>
                        <filter string="Nombre" name="name" domain="[]" context="{'group_by':'name'}"/>
                        <filter string="Cliente" name="partner_id" domain="[]" context="{'group_by':'partner_id'}"/>
                </search>
            </field>
        </record>

        <record id="view_route_order_form" model="ir.ui.view">
            <field name="name">view.routeorder.form</field>
            <field name="model">route.order</field>
            <field name="arch" type="xml">
                <form string="Ruta de Ordenes">
                    <sheet>
                        <header>

                        </header>
                        <div class="oe_title">
                            <label string="Orden" for="name"/>
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>

                                <field name="partner_id"/>
                                <field name="partner_shipping_id"/>
                                <field name="priority"/>
                                <field name="type"/>
                                <field name="state"/>
                            </group>
                            <group>
                                <field name="date_order"/>
                                <field name="manage_id"/>
                                <field name="comentary"/>
                                <field name="stock_picking_id"/>
                                <field name="sale_order_id"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="view_route_order_tree" model="ir.ui.view">
            <field name="name">view.routeorder.list</field>
            <field name="model">route.order</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="partner_id"/>
                    <field name="partner_shipping_id"/>
                    <field name="priority"/>
                    <field name="date_order"/>
                    <field name="manage_id"/>
                    <field name="state"/>
                </list>
            </field>
        </record>



        <record id="route_order_action_generic" model="ir.actions.act_window">
            <field name="name">Ruta de Ordenes</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">route.order</field>
            <field name="view_mode">list,form</field>
        </record>


        <menuitem action="route_order_action_generic" name="Ruta de Ordenes" id="menu_route_order" parent="sale.sale_order_menu" sequence="1"/>

</odoo>
